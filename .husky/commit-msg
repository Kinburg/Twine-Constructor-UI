#!/bin/sh
commit_msg=$(cat "$1")

# Skip validation for merge commits and automated bot commits
case "$commit_msg" in
  Merge\ *) exit 0 ;;
  chore:\ bump\ version\ to\ *) exit 0 ;;
esac

pattern="^(feat|update|fix|site|chore)(\(.+\))?: .+"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo ""
  echo "Invalid commit message format."
  echo ""
  echo "Acceptable formats:"
  echo "feat: description -> minor (1.x.0) — new feature"
  echo "update: description -> patch (1.2.x) — improvement to existing feature"
  echo "fix: description -> patch (1.2.x) — bug fix"
  echo "site: description -> no version change"
  echo "chore: description -> no version change"
  echo ""
  echo "Your commit was: $commit_msg"
  echo ""
  exit 1
fi
